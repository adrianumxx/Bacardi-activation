# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: inviti utente e operazioni admin avanzate (non esporre al client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# URL pubblico dell’app (usato nei link di invito / magic link)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Login: in Supabase → Authentication → Providers abilita:
# - Email (con “Password” / sign up se vuoi registrazione da UI)
# - Google (Client ID / Secret da Google Cloud Console, redirect: https://YOUR_PROJECT.supabase.co/auth/v1/callback
#   e nella console Google aggiungi anche http://localhost:3000/auth/callback se testi in locale)

# URL pubblico Microsoft Bookings usato come fallback (landing, portale, attivazioni senza URL dedicato)
# NEXT_PUBLIC_DEFAULT_BOOKINGS_URL=https://book.ms/b/...
